source .venv/bin/activate

python main.py \
  --task all \
  --encoder-model distilbert-base-uncased \
  --decoder-model Qwen/Qwen2.5-0.5B-Instruct \
  --encoder-batch-size 32 \
  --decoder-batch-size 4 \
  --encoder-max-length 256 \
  --decoder-max-length 256 \
  --decoder-max-new-tokens 8 \
  --train-epochs 3 \
  --learning-rate 5e-4 \
  --weight-decay 1e-2 \
  --shots-per-class 1 \
  --tfidf-max-features 20000 \
  --output-dir results

